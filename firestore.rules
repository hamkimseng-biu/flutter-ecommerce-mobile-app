rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── PUBLIC READ collections (anyone can browse) ──
    match /products/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /categories/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /shops/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /promo_codes/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /reviews/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── USER-SPECIFIC data (requires auth) ──
    match /users/{userId} {
      // Users can read/write their own data
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Nested collections (cart, orders, addresses, etc.)
      match /cart/{doc} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /orders/{doc} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /wishlist/{doc} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /addresses/{doc} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /cards/{doc} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /bank_accounts/{doc} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /notifications/{doc} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /followed_shops/{doc} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // ── ADMIN access to user orders via collectionGroup ──
    // Note: collectionGroup rules must be at the root level
  }
}
